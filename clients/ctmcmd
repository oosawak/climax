#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<MSG
Usage:
  ctmcmd <topic> -- <command...>
  ctmcmd --topic <topic> -- <command...>

Behavior:
- session_id is inferred from tmux session name:
    cmd-<name> / codex-<name> / log-<name>  -> <name>
  or falls back to basename($PWD).
- server_id defaults to hostname (override with CLIMAX_SERVER_ID).

Env:
  CLIMAX_FUNCTIONS_URL, CLIMAX_FUNCTIONS_CODE, CLIMAX_SERVER_ID (optional)
MSG
}

if [ $# -eq 0 ]; then
  usage >&2
  exit 2
fi

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

topic=""
case "${1:-}" in
  --topic)
    topic="${2:-}"
    shift 2
    ;;
  --topic=*)
    topic="${1#--topic=}"
    shift 1
    ;;
  *)
    topic="$1"
    shift 1
    ;;
esac

if [ -z "$topic" ]; then
  echo "Missing topic." >&2
  exit 2
fi

if [ "${1:-}" != "--" ]; then
  echo "Missing -- separator before command." >&2
  usage >&2
  exit 2
fi
shift 1

if [ $# -eq 0 ]; then
  echo "Missing command after --." >&2
  exit 2
fi

infer_session_id() {
  local sess=""
  if command -v tmux >/dev/null 2>&1 && [ -n "${TMUX:-}" ]; then
    sess="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi

  case "$sess" in
    cmd-*) echo "${sess#cmd-}"; return 0 ;;
    codex-*) echo "${sess#codex-}"; return 0 ;;
    log-*) echo "${sess#log-}"; return 0 ;;
    "") ;; 
    *) echo "$sess"; return 0 ;;
  esac

  basename "$(pwd)"
}

session_id="$(infer_session_id)"

exec "$(dirname "$0")/climax-cmdlog" \
  --session-id "$session_id" \
  --topic "$topic" \
  -- "$@"
