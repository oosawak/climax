# Clients: shared Azure Functions endpoint
# Copy to: clients/.env (do not commit)

# Base URL of the deployed Azure Functions
CLIMAX_FUNCTIONS_URL="https://func-api-eedplxgcbbmra.azurewebsites.net"

# Function key (share within your team)
# Get it from the owner, or via Azure CLI if you have access.
CLIMAX_FUNCTIONS_CODE="<配布された function key>"

# Optional: where to save the latest prompt
# CLIMAX_PROMPT_DIR="$HOME/.climax"

# Optional: choose output backend (local|blob)
# CLIMAX_BACKEND="local"
